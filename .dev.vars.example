# Cloudflare Workers ローカル開発用の env テンプレート。
# 実際の値を `.dev.vars`（gitignore 済み）にコピーして使う。
# 本番値は Cloudflare Pages dashboard の Settings > Environment variables に登録。

# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Contact メール送受信アドレス
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=contact@yourdomain.com

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
# ローカル開発時は公式のテストキー（常に PASS / 常に FAIL）が使える
#   常 PASS: site=1x00000000000000000000AA / secret=1x0000000000000000000000000000000AA
#   常 FAIL: site=2x00000000000000000000AB / secret=2x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
